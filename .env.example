# Copy this file to .env and fill in the values before starting the application.

# Port the local Express server listens on
PORT=8003

# Absolute (or relative) path to the folder that will be watched and hashed
ROOT_FOLDER_PATH="./documents"

# Base URL of this local server — used by the React frontend
REACT_APP_API_BASE_URL="http://localhost:8003"

# HealthLOQ API credentials — NEVER commit the real token
REACT_APP_JWT_TOKEN="replace-with-your-jwt-token"
REACT_APP_HEALTHLOQ_API_BASE_URL="https://api.healthloq.com"

# External app URLs referenced by the dashboard
REACT_APP_HEALTHLOQ_ORGANIZATION_APP_BASE_URL="https://partner.healthloq.com"
REACT_APP_HEALTHLOQ_CONSUMER_APP_BASE_URL="https://www.healthloq.com"

# SMTP settings — required for email alert notifications
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="alerts@example.com"
SMTP_PASS="replace-with-smtp-password"
SMTP_FROM="HealthLOQ Alerts <alerts@example.com>"

# Anthropic API key — required for AI auto-populate metadata feature
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY="replace-with-your-anthropic-api-key"

# Optional: set to "debug" for verbose server logs (default: "info")
# LOG_LEVEL=debug
